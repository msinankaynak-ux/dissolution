    given-names: "Mustafa Sinan"
    affiliation: "Anadolu University, Faculty of Pharmacy, Department of Pharmaceutical Technology, Eskişehir, Türkiye"
version: "3.0"
date-released: "2026-06-12"
url: "https://www.dissolva.app"
license: LicenseRef-Proprietary
keywords:
  - dissolution
  - drug release kinetics
  - f2 similarity factor
  - bootstrap f2
  - kinetic modeling
  - pharmaceutical software
