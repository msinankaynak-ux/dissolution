# DissolvA — Streamlit yerleşik OIDC giriş yapılandırması ŞABLONU
# -----------------------------------------------------------------
# 1) Bu dosyayı 'secrets.toml' olarak KOPYALA  (aynı klasöre, .streamlit/secrets.toml)
# 2) Aşağıdaki client_id / client_secret / cookie_secret alanlarını DOLDUR
# 3) GERÇEK secrets.toml dosyasını ASLA git'e ekleme (.gitignore'da hariç tutuldu)
#
# Google OAuth client nasıl alınır (tek seferlik, senin yapman gerekir):
#   - https://console.cloud.google.com/  → bir proje seç/oluştur
#   - "APIs & Services" → "Credentials" → "Create Credentials" → "OAuth client ID"
#   - Application type: "Web application"
#   - Authorized redirect URIs: aşağıdaki redirect_uri ile AYNI olmalı
#       (yerel çalıştırma portuyla eşleşmeli — streamlit varsayılanı 8501)
#   - Oluşunca Client ID + Client Secret'ı buraya yapıştır
#
# cookie_secret üretmek için terminalde:
#   python -c "import secrets; print(secrets.token_hex(32))"

[auth]
# Uygulamayı hangi adres/portta çalıştırıyorsan ona göre ayarla.
# 'streamlit run app.py' varsayılanı 8501; özel port kullanıyorsan değiştir.
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "BURAYA_RASTGELE_64_KARAKTER_HEX_KOY"

[auth.google]
client_id = "BURAYA_GOOGLE_CLIENT_ID"
client_secret = "BURAYA_GOOGLE_CLIENT_SECRET"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
